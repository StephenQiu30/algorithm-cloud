<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.algorithm.cloud</groupId>
        <artifactId>algorithm-service</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>algorithm-notification-service</artifactId>
    <name>algorithm-notification-service</name>
    <description>Algorithm RAG-Enhanced Interactive Teaching System</description>

    <dependencies>

        <!-- 公共模块 -->
        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-core</artifactId>
        </dependency>


        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-mysql</artifactId>
        </dependency>

        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-auth</artifactId>
        </dependency>

        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-rabbitmq</artifactId>
        </dependency>

        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-cache</artifactId>
        </dependency>

        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-websocket</artifactId>
        </dependency>

        <!-- API 模块 -->
        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-api-user</artifactId>
        </dependency>

        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-api-notification</artifactId>
        </dependency>

        <!-- 日志模块 -->
        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-common-log</artifactId>
        </dependency>
        <dependency>
            <groupId>com.algorithm.cloud</groupId>
            <artifactId>algorithm-api-log</artifactId>
        </dependency>

        <!-- MySQL -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
        </dependency>

        <!-- MyBatis-Plus -->
        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
        </dependency>


        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
