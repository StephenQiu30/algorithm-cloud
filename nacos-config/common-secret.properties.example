# MySQL
dev.mysql.datasource.username=root
dev.mysql.datasource.password=your_mysql_password
dev.mysql.datasource.url=jdbc:mysql://localhost:3306/algorithm_cloud?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true&cachePrepStmts=true&prepStmtCacheSize=250&prepStmtCacheSqlLimit=2048&useLocalSessionState=true&useServerPrepStmts=true
# COS
dev.cos.client.accessKey=your_cos_access_key
dev.cos.client.secretKey=your_cos_secret_key
dev.cos.client.region=ap-shanghai
dev.cos.client.bucket=your_cos_bucket
# Elasticsearch
dev.elasticsearch.uris=http://localhost:9200
dev.elasticsearch.username=elastic
dev.elasticsearch.password=your_es_password
# Redis
dev.redis.host=localhost
dev.redis.port=6379
dev.redis.database=0
# dev.redis.password=your_redis_password
# RabbitMQ
dev.rabbitmq.host=localhost
dev.rabbitmq.port=5672
dev.rabbitmq.username=guest
dev.rabbitmq.password=guest
# Sa-Token
dev.sa-token.jwt-secret-key=your_jwt_secret_key
# WebSocket
dev.websocket.port=9090
dev.websocket.boss-thread=4
dev.websocket.worker-thread=16
# Mail
dev.mail.host=smtp.163.com
dev.mail.port=465
dev.mail.username=your_mail_username
dev.mail.password=your_mail_password
# WX
dev.wx.open.app-id=your_wx_app_id
dev.wx.open.app-secret=your_wx_app_secret
dev.wx.qrcode.app-id=your_wx_qrcode_app_id
dev.wx.qrcode.app-secret=your_wx_qrcode_app_secret
dev.wx.qrcode.redirect-uri=http://your-domain.com/api/user/login/wx/callback
# GitHub OAuth2
dev.github.oauth2.client-id=your_github_client_id
dev.github.oauth2.client-secret=your_github_client_secret
dev.github.oauth2.redirect-uri=http://localhost:3000/user/login/github/callback
# AI
dev.aliyun.dashscope.api-key=your_dashscope_api_key
dev.aliyun.dashscope.model-name=qwen-plus
# Nacos
dev.nacos.addr=localhost:8848
dev.nacos.username=nacos
dev.nacos.password=nacos
